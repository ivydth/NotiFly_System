<?xml version="1.0" encoding="utf-8"?>
<!--
    The FrameLayout is the actual RecyclerView item root.
    viewGlow sits BEHIND the CardView and is larger than it,
    so its colored blur bleeds out like a halo underneath.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="108dp"
    android:layout_height="88dp"
    android:layout_marginEnd="6dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!--
        Glow layer — larger than the card, centered behind it.
        Its background color and alpha are set in Java at runtime.
        Starts fully transparent; animates to visible on press.
    -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginStart="-6dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="-6dp"
        android:layout_marginBottom="-10dp"
        android:alpha="0"
        android:background="@drawable/glow_shape" />

    <!-- The actual card — sits on top of the glow -->
    <androidx.cardview.widget.CardView
        android:id="@+id/summaryCard"
        android:layout_width="100dp"
        android:layout_height="80dp"
        android:layout_gravity="top|center_horizontal"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#1E3A4A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AACCDD"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
