<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP APP BAR -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <!-- Back Button -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:contentDescription="Back"
                app:tint="#FFFFFF" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="NotiFly"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Profile -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_profile"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:contentDescription="Profile"
                app:tint="#FFFFFF" />

        </RelativeLayout>

        <!-- Scrollable detail content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingBottom="24dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp">

                <!-- Sender + Date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <!-- Sender avatar circle (blank — filled by Java) -->
                    <View
                        android:id="@+id/senderAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/avatar_teal" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <!-- Sender name -->
                        <TextView
                            android:id="@+id/tvSenderName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sender Name"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- Date -->
                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="March 29, 2026"
                            android:textColor="#AACCDD"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Unread dot -->
                    <View
                        android:id="@+id/unreadDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_blue" />

                </LinearLayout>

                <!-- Detail Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#332E4A5A"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- TITLE label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TITLE"
                            android:textColor="#00C9B1"
                            android:textSize="11sp"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="6dp" />

                        <!-- Notification Title -->
                        <TextView
                            android:id="@+id/tvNotifTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification Title Here"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="20dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#33FFFFFF"
                            android:layout_marginBottom="20dp" />

                        <!-- MESSAGE label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MESSAGE"
                            android:textColor="#00C9B1"
                            android:textSize="11sp"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="10dp" />

                        <!-- Full message body -->
                        <TextView
                            android:id="@+id/tvNotifMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Full notification message content goes here. This is where the complete details of the notification will be displayed to the user."
                            android:textColor="#CCE8FF"
                            android:textSize="15sp"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginBottom="24dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#33FFFFFF"
                            android:layout_marginBottom="20dp" />

                        <!-- DATE label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DATE RECEIVED"
                            android:textColor="#00C9B1"
                            android:textSize="11sp"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="6dp" />

                        <!-- Full date -->
                        <TextView
                            android:id="@+id/tvFullDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="March 29, 2026 — 10:45 AM"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Action buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="2">

                    <!-- Mark as Read -->
                    <Button
                        android:id="@+id/btnMarkRead"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Mark as Read"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@drawable/btn_teal_rounded"
                        app:backgroundTint="@null"
                        android:elevation="4dp" />

                    <!-- Delete -->
                    <Button
                        android:id="@+id/btnDelete"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Delete"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@drawable/btn_delete_rounded"
                        app:backgroundTint="@null"
                        android:elevation="4dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</FrameLayout>
