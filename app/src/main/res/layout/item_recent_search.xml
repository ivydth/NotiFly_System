<?xml version="1.0" encoding="utf-8"?>
<!-- item_recent_search.xml -->
<!-- Use this as a row item in a RecyclerView for the recent searches list -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0B1628">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <!-- Clock / History Icon -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_history"
            android:tint="#8A9BB0"
            android:alpha="0.6"
            android:contentDescription="Recent" />

        <!-- Search Text -->
        <TextView
            android:id="@+id/tvSearchText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:text="Search term" />

        <!-- Arrow / Redirect Icon -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_outward"
            android:tint="#8A9BB0"
            android:contentDescription="Open" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="#0D2A2E" />

</LinearLayout>