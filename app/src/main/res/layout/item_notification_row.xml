<?xml version="1.0" encoding="utf-8"?>
<!--
    item_notification_row.xml
    One row inside the notificationsContainer on UserActivity.
    Key change: ivAvatar is now a TextView so we can show the sender's
    first letter as the avatar, matching the admin HTML panel preview.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!--
        SENDER AVATAR — TextView so we can display the first letter.
        Background drawable gives it the teal circle shape.
        Java sets tvAvatar.setText(letter) in buildNotificationRow().
    -->
    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/fredoka_one"
        android:background="@drawable/avatar_teal"
        android:contentDescription="Sender avatar" />

    <!-- Text block: sender name + message preview + date -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sender Name"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/fredoka_one"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification message preview..."
            android:textColor="#AACCDD"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Right column: date/time + star -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Now"
            android:textColor="#3A6070"
            android:textSize="10sp"
            android:gravity="end" />

        <!-- Star / unstar toggle -->
        <TextView
            android:id="@+id/tvStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★"
            android:textSize="18sp"
            android:textColor="#44AACCDD"
            android:layout_marginTop="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Optional divider — hidden in Java (divider.setVisibility(GONE)) -->
    <View
        android:id="@+id/vDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A5BCCE8"
        android:visibility="gone" />

</LinearLayout>
