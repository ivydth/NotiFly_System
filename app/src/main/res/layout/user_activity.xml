<?xml version="1.0" encoding="utf-8"?>
<!--
    item_summary_card.xml
    Layout for each card in the horizontal summary carousel.

    IMPORTANT: viewUnderglow MUST be the FIRST child of the CardView
    so it renders behind the text content.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="72dp"
    android:layout_marginEnd="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1E3A4A">

    <!--
        Underglow overlay — sits behind everything else.
        Colour is set in Java (tinted to the card's accent colour).
        Alpha is animated between 0 (deselected) and 1 (selected).
    -->
    <View
        android:id="@+id/viewUnderglow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@android:color/white" />

    <!-- Card content — count + label, centred -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Label"
            android:textColor="#A0BFC8"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
