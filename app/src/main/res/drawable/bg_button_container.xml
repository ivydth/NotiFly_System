<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#CC0B1628"/>

    <!-- Border -->
    <stroke
        android:width="2dp"
        android:color="#8A9BB0"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Inner spacing -->
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp"/>
</shape>